{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rapai.tenopa.co.kr/ontology/schemas/gate.json",
  "title": "Gate",
  "description": "A stage-gate review (TRL, CRL, L2-C Client Acceptance, Annual, Moving Target). Append-only Governed decision record.",
  "x-ontology-version": "0.1.0",
  "x-ontology-layer": "L2.5",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_id",
    "project_id",
    "level",
    "status"
  ],
  "properties": {
    "gate_id": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "ULID assigned at creation (immutable)."
    },
    "project_id": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "Parent project ID."
    },
    "level": {
      "$ref": "enums.json#/$defs/GateLevel",
      "description": "Gate level (L1_TRL, L1_CRL, L2_STAGE, L2_C_CLIENT, L3_ANNUAL, L4_MOVING). Source: ADR-002 decision 9."
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "met": {
            "type": "boolean"
          },
          "evidence": {
            "type": "string"
          }
        },
        "required": ["criterion_id", "description"],
        "additionalProperties": false
      },
      "description": "Gating criteria and evidence."
    },
    "status": {
      "$ref": "enums.json#/$defs/GateStatus",
      "description": "Gate status (planned, in_progress, passed, failed, waived)."
    },
    "signed_by": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "Person who signed off on this gate (approver)."
    },
    "snapshot_id": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "Reference to project state snapshot at gate time (append-only)."
    },
    "decision_id": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "Linked Decision record (if gate outcome was contentious)."
    },
    "prov_id": {
      "$ref": "enums.json#/$defs/Identifier",
      "description": "PROV-O Activity ID for lineage."
    },
    "created_at": {
      "$ref": "enums.json#/$defs/ISODateTime"
    },
    "updated_at": {
      "$ref": "enums.json#/$defs/ISODateTime"
    }
  }
}
